@startuml
title MongoDB Document Structure - MultiClassPatients3D_Polygons_CTA41

skinparam shadowing false
skinparam roundCorner 15
skinparam defaultFontName Arial

!define LEVEL1 #D4EDDA
!define LEVEL2 #E8F0FE
!define LEVEL3 #FFF4E5
!define LEVEL4 #FDECEF

node "<b>Collection: MultiClassPatients3D_Polygons_CTA41</b>" as Coll #white {

  object "<b>Root Document</b>" as Root LEVEL1 {
    schema : "3d_polygon"
    patient_id : "topcow_ct_001"
    patient_norm_id : "001"
    target_size : "128x128x64"
    etl_loaded_at : "YYYY-MM-DD HH:mm:ss"
  }

  object "<b>metadata</b>" as Meta LEVEL2 {
    img_path : ".../imagesTr_topbrain_ct/..."
    lbl_path : ".../labelsTr_topbrain_ct/..."
    dimensions : {height, width, depth}
  }

  object "<b>segments</b> (Array)" as SegArray #E0E0E0 {
    [0..N] Segment objects
  }

  object "<b>Segment Object</b>" as SegItem LEVEL3 {
    label_id : 1..40
    polygons : [ Polygon objects ]
  }

  object "<b>Polygon Object</b>" as PolyItem LEVEL4 {
    z_index : 0..D-1
    contours : [ [[x,y], ...], [[x,y], ...] ]
  }
}

Root *-- Meta
Root *-- SegArray
SegArray "1" *-- "N" SegItem
SegItem "1" *-- "M" PolyItem

note bottom of SegArray
Représentation 3D: contours 2D indexés par z
Une classe peut contenir plusieurs polygones et contours.
end note

@enduml
