@startuml
title MongoDB Document Structure - BinaryPatients (TopBrain)

skinparam shadowing false
skinparam roundCorner 15
skinparam defaultFontName Arial

!define LEVEL1 #D4EDDA
!define LEVEL2 #E8F0FE
!define LEVEL3 #FFF4E5

node "<b>Collection: BinaryPatients</b>" as Coll #white {

  object "<b>Root Document</b>" as Root LEVEL1 {
    _id : ObjectId("...")
    patient_id : "001"
    target_size : "128x128x64"
    shape : [128, 128, 64]
  }

  object "<b>Type Metadata</b>" as Types LEVEL2 {
    img_dtype : "float32"
    lbl_dtype : "int64"
  }

  object "<b>Binary Payload</b>" as Payload LEVEL3 {
    img_data : <BinData>
    lbl_data : <BinData>
  }

  object "<b>img_data semantics</b>" as ImgSem #FDECEF {
    preprocessed image volume
    resized + normalized CT
    shape = [D,H,W] / target shape
  }

  object "<b>lbl_data semantics</b>" as LblSem #FDECEF {
    segmentation labels
    int64 multiclass labels
    valid range: 0..40
  }
}

Root *-- Types
Root *-- Payload
Payload *-- ImgSem
Payload *-- LblSem

note bottom of Payload
BinData stores raw bytes generated from numpy arrays
(serialization via tobytes / reconstruction via frombuffer + reshape)
end note

@enduml
