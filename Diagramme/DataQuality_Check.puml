@startuml
title DataQuality Check
left to right direction

start
:Load CTA + SEG;

if (Dimensions valid?) then (yes)
  :Resize to target_size;
else (no)
  :Reject sample;
  stop
endif

if (Finite voxel values?) then (yes)
  :Apply clipping/windowing;
else (no)
  :Set invalid voxels to 0;
endif

if (Normalization in [0,1]?) then (yes)
  :Continue;
else (no)
  :Re-normalize;
endif

if (Label is binary?) then (yes)
  :Store sample;
else (no)
  :Binarize label (>0 => 1);
  :Store sample;
endif

:Write QC log;
stop
@enduml