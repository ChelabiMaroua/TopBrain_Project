@startuml
title MongoDB Document Structure - MultiClassPatients2D_Binary_CTA41

skinparam shadowing false
skinparam roundCorner 15
skinparam defaultFontName Arial

!define LEVEL1 #D4EDDA
!define LEVEL2 #E8F0FE
!define LEVEL3 #FFF4E5

node "<b>Collection: MultiClassPatients2D_Binary_CTA41</b>" as Coll #white {

  object "<b>Root Document</b>" as Root LEVEL1 {
    schema : "2d_binary"
    patient_id : "topcow_ct_001"
    patient_norm_id : "001"
    target_size : "128x128x64"
    slice_idx : 0..63
    shape : [H, W]
  }

  object "<b>Type Metadata</b>" as Types LEVEL2 {
    img_dtype : "float32"
    lbl_dtype : "int64"
  }

  object "<b>Binary Payload</b>" as Payload LEVEL3 {
    img_data : <BinData>
    lbl_data : <BinData>
  }

  object "<b>Source Paths</b>" as Paths LEVEL2 {
    img_path : ".../imagesTr_topbrain_ct/..."
    lbl_path : ".../labelsTr_topbrain_ct/..."
  }
}

Root *-- Types
Root *-- Payload
Root *-- Paths

note bottom of Payload
Chaque document = 1 slice 2D
img_data/lbl_data reconstruits via frombuffer + reshape(shape)
end note

@enduml
