@startuml
caption Figure IV-6 : Processus ETL TopBrain (3D backup + 2D principal + KPI)

skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho

' --- Ligne du haut : Extract et Transform côte à côte ---
left to right direction

rectangle "Extract" as EX {
  component "CTA NIfTI" as CTA
  component "SEG NIfTI\n(masque annoté)" as SEG
  component "Validation T0" as VAL
}

rectangle "Transform" as TR {
  component "Resize 3D" as RS3
  component "Resize 2D" as RS2
  component "Normalisation" as NM
  component "Préparation labels" as LB
  component "Contrôle qualité" as QC
  component "Traçabilité" as TC
}

rectangle "Load" as LD {
  component "BinaryPatients" as BIN3D
  component "MultiClassPatients2D_Binary" as BIN2D
  component "MultiClassPatients2D_Polygons" as POL2D
  component "Logs ETL" as LOG
  database "MongoDB" as MDB
}

rectangle "KPI" as KP {
  component "KPI2 débit" as K2
  component "KPI3 occupation disque" as K3
  component "KPI4 overhead ETL" as K4
}

' --- Forcer Load en dessous des deux autres ---
TR -[hidden]-> LD

' --- Relations principales de bloc à bloc ---
EX --> TR
TR --> LD
LD --> KP

' --- Relations internes (optionnelles, si tu veux les garder) ---
CTA --> VAL
SEG --> VAL

RS3 --> NM
RS2 --> NM
RS3 --> LB
RS2 --> LB
NM --> QC
LB --> QC
QC --> TC


BIN3D --> MDB
BIN2D --> MDB
POL2D --> MDB
LOG --> MDB
K2 --> K3
K3 --> K4
@enduml