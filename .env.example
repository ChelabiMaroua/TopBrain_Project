TOPBRAIN_CHECKPOINT_DIR=4_Unet3D/checkpoints
TOPBRAIN_GRAPHS_DIR=Graphs
TOPBRAIN_RECONSTRUCTION_DIR=Reconstruction
TOPBRAIN_RESULTS_DIR=results
TOPBRAIN_MODELS_DIR=models

# JSON outputs
TOPBRAIN_BENCHMARK_JSON=Graphs/benchmark_results.json
TOPBRAIN_KPI_OUTPUT_JSON=Graphs/kpi_real_metrics.json
