# Paths used by the current training scripts
TOPBRAIN_IMAGE_DIR=C:\path\to\imagesTr_topbrain_ct
TOPBRAIN_LABEL_DIR=C:\path\to\labelsTr_topbrain_ct
TOPBRAIN_PARTITION_FILE=3_Data_Partitionement/partition_materialized.json

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=TopBrain_DB

# 2D collections
TOPBRAIN_2D_BINARY_COLLECTION=MultiClassPatients2D_Binary
TOPBRAIN_2D_POLYGON_COLLECTION=MultiClassPatients2D_Polygons

# 3D collections
MONGO_BINARY_COLLECTION=MultiClassPatients
TOPBRAIN_3D_POLYGON_COLLECTION=PolygonPatients

# Checkpoints and result files
TOPBRAIN_2D_CHECKPOINT_DIR=4_Unet2D/checkpoints
TOPBRAIN_3D_CHECKPOINT_DIR=4_Unet3D/checkpoints
TOPBRAIN_2D_TRAIN_RESULTS_JSON=results/unet2d_train_results.json
TOPBRAIN_3D_TRAIN_RESULTS_JSON=results/unet3d_train_results.json
